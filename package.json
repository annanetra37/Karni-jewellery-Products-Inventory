{
  "name": "karni-sales",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build",
    "start": "tsx scripts/bootstrap.ts && next start -p ${PORT:-3000}",
    "start:web": "next start -p ${PORT:-3000}",
    "lint": "next lint",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "import:catalog": "tsx scripts/import-catalog.ts"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "exceljs": "^4.4.0",
    "jose": "^5.9.6",
    "next": "^15.5.18",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^6.12.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

enum Role {
  SALES
  ADMIN
  SUPER_ADMIN
}

enum SellingPointType {
  PHYSICAL
  ONLINE
  CONSIGNMENT
}

enum VariantStatus {
  ACTIVE
  OUT_OF_STOCK
  ARCHIVED
  COMING_SOON
}

enum StockMovementType {
  SALE
  CHECKIN
  RETURN
  ADJUSTMENT
  TRANSFER
  SAMPLE_GIFT
  DAMAGE_LOSS
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

enum OrderChannel {
  ONLINE
  SALES_POINT
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  READY
  FULFILLED
  CANCELLED
}

enum CashSessionStatus {
  OPEN
  CLOSED
  DISPUTED
}

enum NotificationType {
  NEW_ORDER
  NEW_SALE
  LOW_STOCK
  KACCA_MISMATCH
  INVITE
  BIRTHDAY
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String?
  fullName         String
  birthday         DateTime? @db.Date
  role             Role     @default(SALES)
  isActive         Boolean  @default(true)
  isOwner          Boolean  @default(false) // business owner who shares the safe
  inviteToken      String?  @unique
  inviteAcceptedAt DateTime?
  createdById      String?
  createdBy        User?    @relation("UserInvites", fields: [createdById], references: [id])
  invitedUsers     User[]   @relation("UserInvites")
  createdAt        DateTime @default(now())

  sales            Sale[]            @relation("SoldBy")
  ordersCreated    Order[]           @relation("OrderCreatedBy")
  movementsBy      StockMovement[]   @relation("MovementBy")
  cashOpens        CashDrawerSession[] @relation("CashOpenBy")
  cashCloses       CashDrawerSession[] @relation("CashCloseBy")
  shifts           CashDrawerSession[] @relation("ShiftUser")
  shiftParticipations ShiftParticipant[] @relation("ShiftParticipantUser")
  customersCreated Customer[]        @relation("CustomerCreatedBy")
  inventoryCreated InventoryItem[]   @relation("InventoryCreatedBy")
  returnsPerformed SaleReturn[]      @relation("ReturnPerformedBy")
  receivingBatches ReceivingBatch[]  @relation("ReceivingBatchBy")
  teamNotes        TeamNote[]        @relation("TeamNoteAuthor")
  teamNotesResolved TeamNote[]       @relation("TeamNoteResolvedBy")
  notifications    Notification[]
  adminSellingPoints AdminSellingPoint[]
  safeWithdrawals  SafeTransaction[] @relation("SafeOwner")
  safeRecorded     SafeTransaction[] @relation("SafeBy")

  @@index([birthday])
}

model Design {
  id                  String  @id @default(cuid())
  designId            String  @unique
  nameEn              String
  nameHy              String?
  category            String?
  collection          String?
  subcollection       String?
  motif               String?
  culturalMeaningEn   String?
  culturalMeaningHy   String?
  metal               String?
  plating             String?
  enamelType          String?
  basePriceAmd        Decimal? @db.Decimal(12, 2)
  status              String?
  primaryImageUrl     String?
  notes               String?
  createdAt           DateTime @default(now())
  variants            Variant[]
}

model Variant {
  id            String   @id @default(cuid())
  sku           String   @unique
  designId      String
  design        Design   @relation(fields: [designId], references: [id])
  designName    String
  category      String?
  collection    String?
  subcollection String?
  size          String?
  color         String?
  priceAmd      Decimal  @db.Decimal(12, 2)
  priceUsd      Decimal? @db.Decimal(12, 2)
  priceEur      Decimal? @db.Decimal(12, 2)
  priceRub      Decimal? @db.Decimal(12, 2)
  costAmd       Decimal? @db.Decimal(12, 2)
  metalType        String?
  metalCostAmd     Decimal? @db.Decimal(12, 2)
  fillingMaterial  String?
  fillingCostAmd   Decimal? @db.Decimal(12, 2)
  platingType      String?
  platingCostAmd   Decimal? @db.Decimal(12, 2)
  laborCostAmd     Decimal? @db.Decimal(12, 2)
  barcode       String?  @unique
  imageUrl      String?
  weightG       Decimal? @db.Decimal(10, 3)
  reorderPoint  Int      @default(2)
  // A default add-on (e.g. the accessory chain bundled with pendants) that would
  // otherwise dominate the "most sold" lists — excluded from top-seller reports.
  excludeFromTopSellers Boolean @default(false)
  status        VariantStatus @default(ACTIVE)
  onWebsite     Boolean  @default(false)
  onEtsy        Boolean  @default(false)
  onIg          Boolean  @default(false)
  inStockists   Boolean  @default(false)
  searchBlob    String?  // denormalised lowercase search text for trigram
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inventoryItems InventoryItem[]
  movements      StockMovement[]
  saleLineItems  SaleLineItem[]
  orderLineItems OrderLineItem[]
  returnLineItems SaleReturnLineItem[]

  @@index([category])
  @@index([collection])
  @@index([color])
  @@index([status])
}

model SellingPoint {
  id        String   @id @default(cuid())
  name      String   @unique
  type      SellingPointType
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  inventoryItems InventoryItem[]
  movements      StockMovement[]
  sales          Sale[]
  orders         Order[]
  cashSessions   CashDrawerSession[]
  admins         AdminSellingPoint[]
  safeTransactions SafeTransaction[]
  returns        SaleReturn[]
  receivingBatches ReceivingBatch[]
}

enum SafeTxType {
  DEPOSIT       // cash moved from a drawer into the safe
  WITHDRAWAL    // money taken out of the safe by an owner
  BANK_TO_SAFE  // card revenue moved out of the bank into the safe
}

// Ledger of money moving into / out of the owners' safe.
model SafeTransaction {
  id             String     @id @default(cuid())
  type           SafeTxType
  amountAmd      Decimal    @db.Decimal(12, 2)
  sellingPointId String?    // source drawer for a deposit
  ownerId        String?    // which owner took a withdrawal (null when split)
  splitAll       Boolean    @default(false) // withdrawal shared equally by all owners
  reason         String?    // PERSONAL | INVESTMENT (withdrawals)
  fromDrawer     Boolean    @default(true) // deposit: did this cash come from the drawer? (after-hours sale cash = false)
  performedById  String     // who recorded it
  note           String?
  occurredAt     DateTime   @default(now())
  createdAt      DateTime   @default(now())

  sellingPoint SellingPoint? @relation(fields: [sellingPointId], references: [id])
  owner        User?         @relation("SafeOwner", fields: [ownerId], references: [id])
  performedBy  User          @relation("SafeBy", fields: [performedById], references: [id])

  @@index([type, occurredAt])
  @@index([ownerId])
  @@index([sellingPointId, occurredAt])
}

// Scopes a point-restricted ADMIN to the selling points they may manage.
// Super admins (global) and sales have no rows here.
model AdminSellingPoint {
  userId         String
  sellingPointId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sellingPoint   SellingPoint @relation(fields: [sellingPointId], references: [id], onDelete: Cascade)

  @@id([userId, sellingPointId])
  @@index([sellingPointId])
}

model InventoryItem {
  id             String   @id @default(cuid())
  variantId      String
  sellingPointId String
  quantity       Int      @default(0)
  createdById    String?
  firstSeenAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  variant      Variant      @relation(fields: [variantId], references: [id])
  sellingPoint SellingPoint @relation(fields: [sellingPointId], references: [id])
  createdBy    User?        @relation("InventoryCreatedBy", fields: [createdById], references: [id])

  @@unique([variantId, sellingPointId])
  @@index([sellingPointId])
}

model StockMovement {
  id             String   @id @default(cuid())
  variantId      String
  sellingPointId String
  type           StockMovementType
  qtyDelta       Int
  unitPriceAmd   Decimal? @db.Decimal(12, 2)
  performedById  String
  saleId         String?
  returnId       String?
  batchId        String?
  note           String?
  createdAt      DateTime @default(now())

  variant      Variant      @relation(fields: [variantId], references: [id])
  sellingPoint SellingPoint @relation(fields: [sellingPointId], references: [id])
  performedBy  User         @relation("MovementBy", fields: [performedById], references: [id])
  sale         Sale?        @relation(fields: [saleId], references: [id])
  saleReturn   SaleReturn?  @relation(fields: [returnId], references: [id])
  batch        ReceivingBatch? @relation(fields: [batchId], references: [id])

  @@index([variantId])
  @@index([sellingPointId, createdAt])
  @@index([type, createdAt])
}

model Customer {
  id          String  @id @default(cuid())
  fullName    String
  email       String?
  phone       String?
  birthday    DateTime? @db.Date
  address     String?
  instagram   String?
  gender      String?
  notes       String?
  isLoyalty   Boolean @default(true)
  createdById String?
  createdBy   User?   @relation("CustomerCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  sales   Sale[]
  orders  Order[]
  returns SaleReturn[]

  @@index([phone])
  @@index([email])
  @@index([birthday])
}

model Sale {
  id             String   @id @default(cuid())
  saleNumber     String   @unique
  sellingPointId String
  customerId     String?
  soldById       String
  subtotalAmd    Decimal  @db.Decimal(12, 2)
  discountAmd    Decimal  @default(0) @db.Decimal(12, 2)
  totalAmd       Decimal  @db.Decimal(12, 2)
  currency       String   @default("AMD")
  paymentMethod  PaymentMethod? @default(CASH)
  // A cash sale whose money went straight to the safe (online/delivery order),
  // so it never entered the drawer — excluded from drawer reconciliation.
  cashToSafe     Boolean  @default(false)
  // Portion of a cash sale that did NOT enter the drawer — the customer paid it
  // another way (bank transfer / card) or it was handed straight to the safe.
  // Lowers the drawer's expected cash by this amount without changing the total.
  nonDrawerAmd   Decimal  @default(0) @db.Decimal(12, 2)
  // Where that non-drawer portion went: the safe (true) or the company bank
  // account (false — e.g. card / transfer). Drawer reconciliation is the same
  // either way; this records the destination.
  nonDrawerToSafe Boolean @default(false)
  createdAt      DateTime @default(now())

  sellingPoint SellingPoint @relation(fields: [sellingPointId], references: [id])
  customer     Customer?    @relation(fields: [customerId], references: [id])
  soldBy       User         @relation("SoldBy", fields: [soldById], references: [id])
  lineItems    SaleLineItem[]
  movements    StockMovement[]
  // Returns that credited this sale (the original/gift sale being returned).
  returnsFromThis  SaleReturn[] @relation("ReturnOriginalSale")
  // If this sale was itself created as the exchange purchase of a return.
  returnAsExchange SaleReturn?  @relation("ReturnExchangeSale")

  @@index([sellingPointId, createdAt])
  @@index([soldById, createdAt])
}

model SaleLineItem {
  id           String  @id @default(cuid())
  saleId       String
  variantId    String
  quantity     Int
  unitPriceAmd Decimal @db.Decimal(12, 2)
  lineTotalAmd Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id])
}

// A return / exchange event. Returned goods are restocked (RETURN movements)
// and credited to the customer; any new pieces taken in exchange are a normal
// linked Sale (its own SALE movements). The whole transaction's net cash impact
// on a drawer is captured as a signed `drawerDeltaAmd` (negative = cash refunded
// out) and attributed to a chosen `cashSession` — the drawer the cash actually
// moved through — so it reconciles against the right shift even when recorded
// later, with no change to the original sale's shift. The exchange Sale's cash
// is represented entirely by `drawerDeltaAmd`, so it is excluded from the
// drawer-cash sum in reconciliation (it was paid with returned credit, not new
// money).
model SaleReturn {
  id               String   @id @default(cuid())
  returnNumber     String   @unique
  sellingPointId   String
  customerId       String?
  performedById    String
  originalSaleId   String?  // the original (gift) sale being returned, if known
  exchangeSaleId   String?  @unique // new purchase taken in exchange, if any
  // The cash drawer session the refund/top-up actually passed through. Null =
  // not tied to a drawer (e.g. refunded by bank transfer, or no shift was open),
  // in which case reconciliation falls back to matching by time.
  cashSessionId    String?
  returnedAmd      Decimal  @db.Decimal(12, 2) // credit for returned goods
  exchangeAmd      Decimal  @default(0) @db.Decimal(12, 2) // value of new items taken (denormalised)
  // Signed net cash into(+) / out(−) of the drawer for this whole transaction.
  drawerDeltaAmd   Decimal  @default(0) @db.Decimal(12, 2)
  // Was the credit paid out of the drawer in cash? If false (e.g. refunded by
  // bank transfer), it does not move the drawer.
  refundFromDrawer Boolean  @default(true)
  note             String?
  createdAt        DateTime @default(now())

  sellingPoint SellingPoint @relation(fields: [sellingPointId], references: [id])
  customer     Customer?    @relation(fields: [customerId], references: [id])
  performedBy  User         @relation("ReturnPerformedBy", fields: [performedById], references: [id])
  originalSale Sale?        @relation("ReturnOriginalSale", fields: [originalSaleId], references: [id])
  exchangeSale Sale?        @relation("ReturnExchangeSale", fields: [exchangeSaleId], references: [id])
  cashSession  CashDrawerSession? @relation(fields: [cashSessionId], references: [id])
  lineItems    SaleReturnLineItem[]
  movements    StockMovement[]

  @@index([sellingPointId, createdAt])
  @@index([cashSessionId])
}

// A receiving session: a batch of stock check-ins recorded together, optionally
// with photos of the owner's hand-written "ready for Megamall" book pages so the
// received quantities can be checked against what was written down.
model ReceivingBatch {
  id             String   @id @default(cuid())
  sellingPointId String
  performedById  String
  note           String?
  photoUrls      String[] @default([]) // captured book-page photos
  createdAt      DateTime @default(now())

  sellingPoint SellingPoint @relation(fields: [sellingPointId], references: [id])
  performedBy  User         @relation("ReceivingBatchBy", fields: [performedById], references: [id])
  movements    StockMovement[]

  @@index([sellingPointId, createdAt])
}

model SaleReturnLineItem {
  id           String  @id @default(cuid())
  returnId     String
  variantId    String
  quantity     Int
  unitPriceAmd Decimal @db.Decimal(12, 2)
  lineTotalAmd Decimal @db.Decimal(12, 2)

  saleReturn SaleReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  variant    Variant    @relation(fields: [variantId], references: [id])

  @@index([returnId])
}

model Order {
  id             String       @id @default(cuid())
  orderNumber    String       @unique
  createdById    String
  customerId     String?
  customerName   String?
  address        String?
  note           String?
  deadline       DateTime?
  channel        OrderChannel
  sellingPointId String?
  status         OrderStatus  @default(NEW)
  createdAt      DateTime     @default(now())

  createdBy    User          @relation("OrderCreatedBy", fields: [createdById], references: [id])
  customer     Customer?     @relation(fields: [customerId], references: [id])
  sellingPoint SellingPoint? @relation(fields: [sellingPointId], references: [id])
  lineItems    OrderLineItem[]
}

model OrderLineItem {
  id          String  @id @default(cuid())
  orderId     String
  variantId   String?
  quantity    Int
  description String?

  metalType        String?
  metalCostAmd     Decimal? @db.Decimal(12, 2)
  fillingMaterial  String?
  fillingCostAmd   Decimal? @db.Decimal(12, 2)
  platingType      String?
  platingCostAmd   Decimal? @db.Decimal(12, 2)
  laborCostAmd     Decimal? @db.Decimal(12, 2)
  unitPriceAmd     Decimal? @db.Decimal(12, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant Variant? @relation(fields: [variantId], references: [id])
}

model CashDrawerSession {
  id                  String   @id @default(cuid())
  sellingPointId      String
  userId              String
  openingCountAmd     Decimal  @db.Decimal(12, 2)
  openingById         String
  openingAt           DateTime @default(now())
  closingCountAmd     Decimal? @db.Decimal(12, 2)
  closingById         String?
  closingAt           DateTime?
  expectedClosingAmd  Decimal? @db.Decimal(12, 2)
  discrepancyAmd      Decimal? @db.Decimal(12, 2)
  priorClosingAmd     Decimal? @db.Decimal(12, 2)
  handoverMismatch    Boolean  @default(false)
  status              CashSessionStatus @default(OPEN)
  note                String?

  sellingPoint SellingPoint @relation(fields: [sellingPointId], references: [id])
  user         User         @relation("ShiftUser", fields: [userId], references: [id])
  openingBy    User         @relation("CashOpenBy", fields: [openingById], references: [id])
  closingBy    User?        @relation("CashCloseBy", fields: [closingById], references: [id])
  breaks       ShiftBreak[]
  participants ShiftParticipant[]
  returns      SaleReturn[]

  @@index([sellingPointId, status])
  @@index([userId, openingAt])
}

model ShiftBreak {
  id        String    @id @default(cuid())
  sessionId String
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  session CashDrawerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// Who is working a shift. The drawer (CashDrawerSession) is shared per selling
// point and counted once; each sales rep present is a participant. The first to
// arrive opens (counts the drawer) and is a participant; others join without
// recounting. Sales are still attributed per rep via Sale.soldById; this records
// attendance/hours and lets every participant see they're on shift.
model ShiftParticipant {
  id        String    @id @default(cuid())
  sessionId String
  userId    String
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?

  session CashDrawerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User              @relation("ShiftParticipantUser", fields: [userId], references: [id])

  @@index([sessionId])
  @@index([userId, joinedAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?  // null = broadcast to all admins
  user      User?    @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String?
  relatedId String?
  isRead    Boolean  @default(false) // per-user notifications only
  readBy    String[] @default([])    // user ids who read a broadcast
  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
}

// A shared note any signed-in user can post for the whole team — handover info,
// "customer X will come back tomorrow for Y", reminders. Visible to everyone so
// the next person on shift stays updated. Anyone can mark one done.
model TeamNote {
  id           String    @id @default(cuid())
  body         String
  authorId     String
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime  @default(now())

  author     User  @relation("TeamNoteAuthor", fields: [authorId], references: [id])
  resolvedBy User? @relation("TeamNoteResolvedBy", fields: [resolvedById], references: [id])

  @@index([resolvedAt, createdAt])
}

model FxRate {
  id            String   @id @default(cuid())
  currency      String   @unique
  ratePerAmd    Decimal  @db.Decimal(18, 8)
  updatedAt     DateTime @updatedAt
}

model Counter {
  id      String @id
  current Int    @default(0)
}

model CollectionMeta {
  id        String   @id @default(cuid())
  name      String   @unique
  nameHy    String?
  nameRu    String?
  imageUrl  String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model CategoryMeta {
  id        String   @id @default(cuid())
  name      String   @unique
  nameHy    String?
  nameRu    String?
  imageUrl  String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}
